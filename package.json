{
  "name": "ocg-manager-ui",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.2",
  "type": "module",
  "scripts": {
    "predev": "node scripts/free-dev-port.mjs",
    "dev": "vite",
    "dev:gui": "tauri dev",
    "build": "node scripts/release.mjs",
    "build:web": "vue-tsc && vite build",
    "test": "cargo test --workspace && node --experimental-strip-types --test src/views/accounts-usage.test.ts src/views/dashboard-connection.test.ts src/views/logs.test.ts src/theme.test.ts && vue-tsc --noEmit",
    "design:lint": "npx -y @google/design.md@0.3.0 lint DESIGN.md"
  },
  "dependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@vicons/antd": "^0.13.0",
    "naive-ui": "^2.44.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitejs/plugin-vue": "^5",
    "typescript": "^5",
    "vite": "^5",
    "vue": "^3",
    "vue-tsc": "^2"
  }
}
