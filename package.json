{
  "name": "ocg-manager-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.29.2",
  "type": "module",
  "scripts": {
    "predev": "node scripts/free-dev-port.mjs",
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc && vite build",
    "build:gateway": "cargo build -p ocg-core",
    "test:gateway": "cargo test -p ocg-core",
    "debug:gateway": "cargo run --bin ocg-manager-cli -- serve",
    "build:cli": "cargo build --release --bin ocg-manager-cli",
    "test:cli": "cargo test -p ocg-manager-cli",
    "debug:cli": "cargo run --bin ocg-manager-cli --",
    "build:gui": "tauri build",
    "test:gui": "vue-tsc --noEmit",
    "dev:gui": "tauri dev",
    "debug:gui": "tauri dev",
    "build:all": "pnpm run build:gateway && pnpm run build:cli && pnpm run build:gui",
    "test": "pnpm run test:gateway && pnpm run test:cli && pnpm run test:gui",
    "verify": "pnpm run test:gateway && pnpm run test:cli && vue-tsc --noEmit",
    "fmt": "cargo fmt --all",
    "clean": "node -e \"const { rmSync } = require('node:fs'); for (const p of ['dist', 'playwright-out']) rmSync(p, { recursive: true, force: true });\" && cargo clean"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2.11.4",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@vicons/antd": "^0.13.0",
    "naive-ui": "^2.44.1",
    "vfonts": "^0.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@vitejs/plugin-vue": "^5",
    "typescript": "^5",
    "vite": "^5",
    "vue": "^3",
    "vue-tsc": "^2"
  }
}
