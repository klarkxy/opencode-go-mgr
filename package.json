{
  "name": "ocg-manager-ui",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.2",
  "type": "module",
  "scripts": {
    "predev": "node scripts/free-dev-port.mjs",
    "dev": "vite",
    "build": "pnpm run build:all && pnpm run artifacts",
    "build:web": "vue-tsc && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1",
    "dev:gateway": "cargo run --bin ocg-manager-cli -- serve",
    "build:gateway": "cargo build -p ocg-core",
    "test:gateway": "cargo test -p ocg-core",
    "dev:cli": "cargo run --bin ocg-manager-cli --",
    "build:cli": "cargo build --release --bin ocg-manager-cli",
    "test:cli": "cargo test -p ocg-manager-cli",
    "dev:gui": "tauri dev",
    "build:gui": "node -e \"require('node:fs').rmSync('target/release/dist', { recursive: true, force: true })\" && tauri build",
    "test:gui": "node --experimental-strip-types --test src/views/accounts-usage.test.ts && pnpm run typecheck",
    "build:all": "pnpm run build:gateway && pnpm run build:cli && pnpm run build:gui",
    "artifacts": "node scripts/collect-artifacts.mjs",
    "test": "pnpm run test:gateway && pnpm run test:cli && pnpm run test:gui",
    "verify": "pnpm run test",
    "fmt": "cargo fmt --all",
    "clean": "node -e \"const { rmSync } = require('node:fs'); for (const p of ['dist', 'release']) rmSync(p, { recursive: true, force: true });\" && cargo clean"
  },
  "dependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@vicons/antd": "^0.13.0",
    "naive-ui": "^2.44.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitejs/plugin-vue": "^5",
    "typescript": "^5",
    "vite": "^5",
    "vue": "^3",
    "vue-tsc": "^2"
  }
}
