{
  "build": {
    "beforeBuildCommand": "pnpm run build:web",
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:30001",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": {
      "../dist": "dist"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer.nsh"
      }
    }
  },
  "identifier": "com.klarkxy.ocgmanager",
  "productName": "OCG Manager",
  "version": "1.0.0",
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:9042; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "capabilities": ["default"]
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "OCG Manager",
        "width": 1200,
        "visible": false
      }
    ]
  },
  "plugins": {}
}
