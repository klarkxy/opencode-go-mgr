OCG_PORT=9042
# Recommended for production: pin an exact release. Use latest only for intentional rolling upgrades.
# Set ocg-manager:local instead when building the current checkout from source.
# OCG_IMAGE=ghcr.io/klarkxy/opencode-go-mgr:1.4.1
# Optional first-start bootstrap. Uncomment both and replace the password, or leave both unset
# so the first dashboard visitor creates the administrator. Remove them after initialization.
# OCG_ADMIN_USERNAME=admin
# OCG_ADMIN_PASSWORD=replace-with-a-long-random-password
# Advanced restore option: use the same value that protected the original data directory.
# OCG_MANAGER_ENCRYPTION_KEY=replace-with-the-original-key
# OCG_CLIENT_ROOT_URL=https://ocg.example.com
# Source-build only; these do not affect a pulled image.
# NPM_REGISTRY=https://registry.npmjs.org
# CARGO_REGISTRY=sparse+https://index.crates.io/
